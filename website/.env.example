# ========== 应用基础配置（组员无需修改，除了APP_KEY） ==========
APP_NAME=lab_api
APP_ENV=local
APP_KEY= # 【组员必做】拉取代码后执行 php artisan key:generate 自动生成
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Shanghai # 时区统一为北京时间

# ========== 日志配置 ==========
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_FILE=lab_api.log

# ========== 数据库配置（核心！组员需按本地环境修改） ==========
DB_CONNECTION=mysql
DB_HOST=127.0.0.1 # 本地数据库地址，默认无需改
DB_PORT=3306 # 若本地MySQL端口不是3306（如3307），组员自行修改
DB_DATABASE=lab_api # 数据库名必须统一为lab_api，组员需先本地创建该数据库
DB_USERNAME=root # 本地MySQL用户名，默认root，有修改的组员自行调整
DB_PASSWORD= # 【组员必做】填写自己本地MySQL的密码（如123456/root，无密码则留空）
DB_CHARSET=utf8mb4 # 字符集统一，无需修改
DB_COLLATION=utf8mb4_unicode_ci # 排序规则统一，无需修改

# ========== 会话/缓存配置 ==========
BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=720 # 登录态保留12小时，无需修改

# ========== Redis配置（暂未用到，默认即可） ==========
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ========== 邮件配置（暂未用到，默认即可） ==========
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

# ========== AWS/Pusher配置（暂未用到，默认即可） ==========
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ========== 业务扩展配置（无需修改） ==========
FILESYSTEM_DISK=local
UPLOAD_PATH=uploads
CORS_ALLOWED_ORIGINS=*
APP_APPLY_SWITCH=1
