# 基础环境（团队统一）
APP_NAME=website
APP_ENV=local
APP_KEY=【执行php artisan key:generate生成】
APP_DEBUG=true
APP_URL=http://localhost

# 数据库（组员替换自己的信息）
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=website  # 本地需先创建这个数据库
DB_USERNAME=root         # 本地MySQL用户名（通常是root）
DB_PASSWORD=【你的MySQL密码，无密码则留空】

# 缓存/会话（无需修改）
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# 日志（无需修改）
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# 邮件（暂时用不到，保留占位）
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
