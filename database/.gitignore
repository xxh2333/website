# ==============================================
# 1. Laravel 框架核心忽略规则（必加）
# ==============================================
# 环境配置文件（含数据库密码、API密钥等敏感信息，绝对不能上传！）
.env
.env.local
.env.*.local
# 依赖包目录（体积大，本地 composer install 自动生成，无需上传）
/vendor/
# 日志文件
/storage/logs/*.log
/storage/logs/*.log.*
# 缓存、编译文件
/storage/cache/
/bootstrap/cache/
# 单元测试覆盖率报告
/coverage/
# 临时文件
*.tmp
*.temp

# ==============================================
# 2. IDE/编辑器配置（你截图里的 .idea 就是这个）
# ==============================================
# PhpStorm/IDEA 本地配置（整个文件夹直接忽略）
.idea/
*.iml
*.iws
*.ipr
# VS Code 配置（如果用的话）
.vscode/
# 编辑器临时文件
*~
*.swp
*.swo

# ==============================================
# 3. 系统生成的垃圾文件
# ==============================================
# Windows
Thumbs.db
.DS_Store
# macOS
.AppleDouble
.LSOverride
Icon
# Linux
.fuse_hidden*

# ==============================================
# 4. 其他可选忽略（根据你的项目选）
# ==============================================
# 节点依赖（如果有前端）
/node_modules/
# 打包产物
/dist/
/build/
# 本地开发服务器配置
docker-compose.override.yml
